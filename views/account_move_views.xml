<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_form_inherit_fel" model="ir.ui.view">
        <field name="name">account.move.form.inherit.torelo.fel</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Header button (only vendor bills/refunds) -->
            <xpath expr="//header" position="inside">
                <button name="action_open_fel_wizard" type="object" string="Crear FEL" class="btn-primary"
                        attrs="{'invisible': [('move_type', 'not in', ('in_invoice','in_refund'))]}"/>
            </xpath>

            <!-- Smart button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object" name="action_view_fel_documents" class="oe_stat_button" icon="fa-file-text-o"
                        attrs="{'invisible': [('move_type', 'not in', ('in_invoice','in_refund'))]}">
                    <field name="fel_count" widget="statinfo" string="FEL"/>
                </button>
            </xpath>

            <!-- Summary fields -->
            <xpath expr="//sheet//group" position="after">
                <group string="FEL" attrs="{'invisible': [('fel_count', '=', 0)]}">
                    <group>
                        <field name="fel_total_amount" readonly="1"/>
                        <field name="fel_ok" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
