<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add "Escanear FEL" button to Vendor Bill form -->
    <record id="view_account_move_form_inherit_ai" model="ir.ui.view">
        <field name="name">account.move.form.inherit.kesiyos.ai</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_ai_scanner"
                        type="object"
                        string="📄 ESCANEAR FEL"
                        class="btn-secondary"
                        attrs="{'invisible': [('move_type', 'not in', ['in_invoice', 'in_refund'])]}"/>
            </xpath>
        </field>
    </record>

</odoo>
