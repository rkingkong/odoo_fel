<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_ai_product_wizard_form" model="ir.ui.view">
        <field name="name">purchase.ai.product.wizard.form</field>
        <field name="model">purchase.ai.product.wizard</field>
        <field name="arch" type="xml">
            <form string="📦 Asignar Producto a Línea">
                <sheet>
                    <div style="padding:10px;background:#fff3cd;border-left:4px solid #ffc107;border-radius:4px;margin-bottom:16px;">
                        <b>Producto no encontrado en el catálogo.</b><br/>
                        Elige qué hacer con esta línea de la factura.
                    </div>
                    <group>
                        <field name="action" widget="radio" string="¿Qué hacer?"/>
                    </group>
                    <div attrs="{'invisible': [('action', '!=', 'viaticos')]}"
                         style="padding:10px;background:#d1ecf1;border-left:4px solid #17a2b8;border-radius:4px;margin:8px 0;">
                        <b>💼 Viáticos / Gasto General</b><br/>
                        Se asignará el producto genérico <b>KES-VIAT</b> a esta línea.
                    </div>
                    <group attrs="{'invisible': [('action', '!=', 'create')]}" string="Datos del Nuevo Producto">
                        <field name="product_name" string="Nombre"/>
                        <field name="product_type" string="Tipo" widget="radio"/>
                        <field name="categ_id" string="Categoría"/>
                        <field name="uom_id" string="Unidad de Medida"/>
                    </group>
                    <field name="line_id" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object" string="✅ Confirmar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
